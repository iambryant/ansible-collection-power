#cloud-config
hostname: {{ item.hostname }}
manage_etc_hosts: true
fqdn: {{ item.hostname }}.{{ item.domain }}

# TO DO: Figure out how to disable root

bootcmd:
  - [ chvg, -g, rootvg ]
  - [ chfs, -a, "size=+8G", /var ]
  - [ chfs, -a, "size=+8G", /opt ]

chpasswd:
  expire: False
users:
  - name: ops
    gecos: Management user
    shell: /bin/bash
    lock_passwd: false
    ssh_authorized_keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIAlP3nVosCYpq5btR1Ha1W3nCvPo7Ua6+W/hVZaCWh6v b77@77.local

runcmd:
  - /opt/freeware/bin/dnf install sudo -y
  - |
    cat << 'EOF' > /etc/sudoers.d/90-cloud-init-users
    # User rules for ops
    ops ALL=(ALL) NOPASSWD:ALL
    EOF
  - chmod 440 /etc/sudoers.d/90-cloud-init-users
