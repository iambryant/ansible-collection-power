set timeout=1
menuentry 'Install OS' {
    insmod http
    insmod tftp
    set root=tftp,{{ lpar_install_netboot_ip }}
    echo 'Loading OS Install kernel ...'
    linux /ppc/ppc64/vmlinuz nameserver={{ lpar_install_dns_ip }} inst.repo=http://{{ lpar_install_netboot_ip }}:/almalinux8/ inst.ks=http://{{ lpar_install_netboot_ip }}/kickstarts/{{ item.hostname}}.ks
    initrd /ppc/ppc64/initrd.img
}
